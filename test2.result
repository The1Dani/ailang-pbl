(prog 
	(stat \n) 
	(stat (func_def function custom_funtion <- ( threshold , replace_value , what_to_replace , dataset ) (context { 
	(stat \n) 
	(stat (doIfElse do (context { 
	(stat \n) 
	(stat (column_ref_op (column dataset . what_to_replace) <- (expr (id replace_value)) \n)) }) 
	if (bool_context { \n (bool_group 
	(bool_stat (expr (column dataset . what_to_replace)) (bool_op <) (expr (id threshold)))) \n }))) 
	(stat \n) }) \n)) 
	(stat \n) 
	(stat \n) 
	(stat (block -> (label @ Load) (context { 
	(stat \n) 
	(stat (fromToData from "train.csv" -> train_data)) 
	(stat \n) 
	(stat (fromToData from "test.csv" -> test_data)) 
	(stat \n) 
	(stat (assignment (id experiment_data) := (expr (id train_data)) \n)) }))) 
	(stat (block -> (label @ Features) (context { 
	(stat \n) 
	(stat \n) 
	(stat (column_ref_op (column experiment_data . FamilySize) <- (expr (expr (expr (column experiment_data . SibSp)) + (expr (column experiment_data . Parch))) + (expr (basic_val (num 1)))) \n)) 
	(stat \n) 
	(stat (doIfElse do (context { 
	(stat \n) 
	(stat (column_ref_op (column experiment_data . Sex) <- (expr (basic_val (num 1))) \n)) }) 
	if (bool_context { \n (bool_group 
	(bool_stat (expr (column experiment_data . Sex)) (bool_op ==) (expr (basic_val (str "male"))))) \n }) 
	else (context { 
	(stat \n) 
	(stat (column_ref_op (column experiment_data . Sex) <- (expr (basic_val (num 0))) \n)) }))) 
	(stat \n) 
	(stat \n) 
	(stat \n) 
	(stat \n) }))) 
	(stat (block -> (label @ Transform) (context { 
	(stat \n) 
	(stat \n) 
	(stat (ref_op (id y) <- (expr (column experiment_data . Survived)) \n)) 
	(stat (column_ref_op (column X_std . rest) <- (expr (list ( (expr (id y)) , (expr (id experiment_data)) ))) \n)) 
	(stat \n) 
	(stat \n) 
	(stat (ref_op (id scaler) <- (expr (func . StandardScaler)) \n)) 
	(stat \n) 
	(stat \n) 
	(stat \n) 
	(stat \n) 
	(stat (column_ref_op (column std_scaler_main . fit_transform) <- (expr (id X_std)) \n)) 
	(stat \n) 
	(stat \n) 
	(stat \n) 
	(stat \n) 
	(stat (expr (column_method (column X_std . StandardScaler) . fit_transform)) \n) 
	(stat \n) 
	(stat (ref_op (id X_scaled) <- (expr (id X_std)) \n)) 
	(stat \n) }))) 
	(stat (block -> (label @ Train) (context { 
	(stat \n) 
	(stat (ref_op (id model) \n <- (expr (func . RandomForestClass
	ifier \n <- (arg_list ( (arg (named_arg n_estimators = (expr (basic_val (num 100))))) , (arg (named_arg max_depth = (expr (basic_val (num 5))))) , (arg (named_arg random_state = (expr (basic_val (num 42))))) )))) \n)) 
	(stat \n) 
	(stat (assignment (id features) := (expr (list (basic_list ( (str "Pclass") , (str "Sex") , (str "Fare") )))) \n)) 
	(stat \n) 
	(stat (ref_op (id X) <- (expr (column_method (column experiment_data . @ features) . get_dummies)) \n)) 
	(stat (ref_op (id X_test) <- (expr (column_method (column test_data . @ features) . get_dummies)) \n)) 
	(stat \n) 
	(stat \n) 
	(stat (column_ref_op (column scaler . fit_transform) <- (expr (id X)) \n)) 
	(stat (expr (column_method (column X . scaler) . fit_transform)) \n) 
	(stat (expr (column_method (column X_test . scaler) . fit_transform)) \n) 
	(stat \n) 
	(stat (column_ref_op (column model . fit) <- (expr (list ( (expr (id X)) , (expr (id y)) ))) \n)) 
	(stat \n) 
	(stat (ref_op (id predictions) \n <- (expr (id model)))) 
	(stat (expr (func . predict \n <- (arg_list ( (arg (expr (id X_test))) )))) \n) 
	(stat \n) }))) 
	(stat (block -> (label @ Output) (context { 
	(stat \n) 
	(stat \n) 
	(stat (column_ref_op (column out . PassengerId) <- (expr (column test_data . PassengerId)) \n)) 
	(stat (column_ref_op (column out . Survived) <- (expr (id predictions)) \n)) 
	(stat (column_ref_op (column out . to_csv) <- (expr (basic_val ( (basic_val (str "result.csv")) ))) \n)) 
	(stat \n) }))) 
	(stat \n) 
	(stat \n)
)
